<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('../../partials/app_head', { title: title }) %>
</head>
<body class="page-bg min-h-screen text-ink-900">
  <%- include('../../partials/admin_shell_open', {
    adminMainExtraClass: 'pb-28',
    adminInnerClass: 'relative mx-auto max-w-7xl px-4 pb-8 pt-0 sm:px-6 lg:px-8 lg:pb-10'
  }) %>

      <div class="animate-fadeUp">
        <div class="mx-auto mb-5 w-full max-w-5xl text-center">
          <!-- <p class="trust-badge inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold text-brand-900 shadow-soft">
            <span aria-hidden="true">🔒</span>
            <%= formType === 'cardiology' ? 'Intake kardiologi (akun klinik)' : 'Pasien baru (akun klinik)' %>
          </p> -->
        </div>

        <div class="card-surface glass-card mx-auto w-full max-w-5xl p-4 sm:p-6 lg:p-8">
        <%- include('../../partials/flash') %>

        <form action="/admin/patients/new" method="POST" enctype="multipart/form-data" class="js-submit-form space-y-8">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="form_type" value="<%= formType %>">

          <%
            const o = (typeof old !== 'undefined' && old) ? old : {};
            function arrify(v) {
              if (v == null || v === '') return [];
              return Array.isArray(v) ? v : [v];
            }
            let medRows = [{ name: '', dose: '', freq: '' }];
            const mn = arrify(o.med_name);
            const md = arrify(o.med_dose);
            const mf = arrify(o.med_freq);
            if (mn.length || md.length || mf.length) {
              const n = Math.max(mn.length, md.length, mf.length, 1);
              medRows = [];
              for (let i = 0; i < n; i += 1) {
                medRows.push({ name: mn[i] || '', dose: md[i] || '', freq: mf[i] || '' });
              }
            }
            function examFromOld(prefix) {
              if (o[prefix + '_mode']) {
                return {
                  mode: o[prefix + '_mode'] === 'pdf' ? 'pdf' : 'text',
                  text: o[prefix + '_text'] != null ? String(o[prefix + '_text']) : '',
                  pdf: o[prefix + '_existing_pdf'] != null ? String(o[prefix + '_existing_pdf']) : ''
                };
              }
              return { mode: 'text', text: '', pdf: '' };
            }
            const examEcg = examFromOld('ecg');
            const examEcho = examFromOld('echo');
            const examLab = examFromOld('lab');
            let apptRows = [{ dt: '', note: '' }];
            const apd = arrify(o.appt_datetime);
            const apn = arrify(o.appt_note);
            if (apd.length || apn.length) {
              const n = Math.max(apd.length, apn.length, 1);
              apptRows = [];
              for (let i = 0; i < n; i += 1) {
                apptRows.push({ dt: apd[i] || '', note: apn[i] || '' });
              }
            }
            const notesVal = (o.clinical_notes != null) ? String(o.clinical_notes) : '';
          %>

          <section class="rounded-[1.75rem] border border-brand-100 bg-brand-50/60 p-4 sm:p-6">
            <div class="mb-6 flex items-center gap-3">
              <div class="stat-icon" aria-hidden="true">👤</div>
              <div>
                <h2 class="text-xl font-extrabold tracking-tight text-ink-900 sm:text-2xl">Data diri</h2>
                <p class="text-sm text-ink-500">Identitas dan kontak.</p>
              </div>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
              <div>
                <label class="field-label" for="pf-first">Nama depan</label>
                <input id="pf-first" type="text" name="first_name" class="field-input" placeholder="Contoh: Budi" required value="<%= o.first_name || '' %>" autocomplete="given-name">
              </div>

              <div>
                <label class="field-label" for="pf-last">Nama belakang</label>
                <input id="pf-last" type="text" name="last_name" class="field-input" placeholder="Contoh: Santoso" required value="<%= o.last_name || '' %>" autocomplete="family-name">
              </div>

              <div>
                <label class="field-label" for="pf-dob">Tanggal lahir</label>
                <input id="pf-dob" type="date" name="date_of_birth" class="field-input" value="<%= o.date_of_birth || '' %>">
              </div>

              <div>
                <label class="field-label" for="pf-gender">Jenis kelamin</label>
                <select id="pf-gender" name="gender" class="field-select">
                  <option value="">Pilih…</option>
                  <option value="male" <%= o.gender === 'male' ? 'selected' : '' %>>Laki-laki</option>
                  <option value="female" <%= o.gender === 'female' ? 'selected' : '' %>>Perempuan</option>
                  <option value="other" <%= o.gender === 'other' ? 'selected' : '' %>>Lainnya</option>
                </select>
              </div>

              <div>
                <label class="field-label" for="pf-phone">Telepon</label>
                <input id="pf-phone" type="text" name="phone" class="field-input" placeholder="+62…" value="<%= o.phone || '' %>" autocomplete="tel">
              </div>

              <div>
                <label class="field-label" for="pf-email">Email</label>
                <input id="pf-email" type="email" name="email" class="field-input" placeholder="nama@email.com" value="<%= o.email || '' %>" autocomplete="email">
              </div>

              <div class="md:col-span-2">
                <label class="field-label" for="pf-address">Alamat</label>
                <textarea id="pf-address" name="address" class="field-textarea" placeholder="Alamat lengkap" autocomplete="street-address"><%= o.address || '' %></textarea>
              </div>
            </div>
          </section>

          <% if (formType === 'cardiology') { %>

          <section class="rounded-[1.75rem] border border-brand-100 bg-white p-4 sm:p-6">
            <div class="mb-6 flex items-center gap-3">
              <div class="stat-icon" aria-hidden="true">🫀</div>
              <div>
                <h2 class="text-xl font-extrabold tracking-tight text-ink-900 sm:text-2xl">Diagnosis &amp; riwayat</h2>
                <p class="text-sm text-ink-500">Diagnosis utama, tambahan, dan riwayat kardiologi.</p>
              </div>
            </div>

            <div class="grid gap-5">
              <div>
                <label class="field-label" for="pf-primary">Diagnosis utama</label>
                <input
                  id="pf-primary"
                  type="text"
                  name="primary_diagnosis"
                  class="field-input"
                  placeholder="Contoh: penyakit arteri koroner"
                  value="<%= o.primary_diagnosis || '' %>"
                >
              </div>

              <div>
                <label class="field-label" for="pf-secondary">Diagnosis sekunder</label>
                <textarea
                  id="pf-secondary"
                  name="secondary_diagnoses"
                  class="field-textarea"
                  placeholder="Daftar diagnosis tambahan…"
                ><%= o.secondary_diagnoses || '' %></textarea>
              </div>

              <div>
                <label class="field-label" for="pf-cardiac">Riwayat jantung</label>
                <textarea
                  id="pf-cardiac"
                  name="cardiac_history"
                  class="field-textarea"
                  placeholder="Tindakan sebelumnya, rawat inap, operasi…"
                ><%= o.cardiac_history || '' %></textarea>
              </div>
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-brand-100 bg-white p-4 sm:p-6">
            <div class="mb-6 flex items-center gap-3">
              <div class="stat-icon" aria-hidden="true">⚠️</div>
              <div>
                <h2 class="text-xl font-extrabold tracking-tight text-ink-900 sm:text-2xl">Faktor risiko</h2>
                <p class="text-sm text-ink-500">Pilih yang sesuai — ukuran ringkas di ponsel.</p>
              </div>
            </div>

            <div class="chips-risk">
              <label class="chip chip-compact">
                <input class="chip-input" type="checkbox" name="has_hypertension" <%= o.has_hypertension ? 'checked' : '' %>>
                <span class="chip-label">Hipertensi</span>
              </label>

              <label class="chip chip-compact">
                <input class="chip-input" type="checkbox" name="has_diabetes" <%= o.has_diabetes ? 'checked' : '' %>>
                <span class="chip-label">Diabetes</span>
              </label>

              <label class="chip chip-compact">
                <input class="chip-input" type="checkbox" name="has_dyslipidemia" <%= o.has_dyslipidemia ? 'checked' : '' %>>
                <span class="chip-label">Dislipidemia</span>
              </label>

              <label class="chip chip-compact">
                <input class="chip-input" type="checkbox" name="has_smoking" <%= o.has_smoking ? 'checked' : '' %>>
                <span class="chip-label">Merokok</span>
              </label>

              <label class="chip chip-compact">
                <input class="chip-input" type="checkbox" name="has_obesity" <%= o.has_obesity ? 'checked' : '' %>>
                <span class="chip-label">Obesitas</span>
              </label>

              <label class="chip chip-compact">
                <input class="chip-input" type="checkbox" name="has_family_history" <%= o.has_family_history ? 'checked' : '' %>>
                <span class="chip-label">Riwayat keluarga</span>
              </label>

              <label class="chip chip-compact">
                <input class="chip-input" type="checkbox" name="has_ckd" <%= o.has_ckd ? 'checked' : '' %>>
                <span class="chip-label">CKD</span>
              </label>

              <label class="chip chip-compact">
                <input class="chip-input" type="checkbox" name="has_previous_mi" <%= o.has_previous_mi ? 'checked' : '' %>>
                <span class="chip-label">Infark sebelumnya</span>
              </label>

              <label class="chip chip-compact">
                <input class="chip-input" type="checkbox" name="has_atrial_fibrillation" <%= o.has_atrial_fibrillation ? 'checked' : '' %>>
                <span class="chip-label">Atrial fibrilasi</span>
              </label>
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-brand-100 bg-white p-4 sm:p-6">
            <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <div class="stat-icon" aria-hidden="true">💊</div>
                <div>
                  <h2 class="text-xl font-extrabold tracking-tight text-ink-900 sm:text-2xl">Obat</h2>
                  <p class="text-sm text-ink-500">Satu baris per obat — tambah jika perlu.</p>
                </div>
              </div>
              <button type="button" class="text-sm font-bold text-brand-800 underline decoration-brand-300 underline-offset-2 hover:text-brand-950" data-clinical-add="#med-rows">
                + Tambah obat
              </button>
            </div>

            <div id="med-rows" class="space-y-4">
              <% medRows.forEach(function (row) { %>
                <div class="rounded-2xl border border-slate-100 bg-slate-50/40 p-4" data-clinical-row>
                  <div class="grid gap-4 sm:grid-cols-3">
                    <div>
                      <span class="field-label">Nama obat</span>
                      <input type="text" name="med_name" class="field-input" placeholder="Contoh: Aspirin" value="<%= row.name %>">
                    </div>
                    <div>
                      <label class="field-label">Dosis</label>
                      <input type="text" name="med_dose" class="field-input" placeholder="80 mg" value="<%= row.dose %>">
                    </div>
                    <div>
                      <label class="field-label">Frekuensi</label>
                      <input type="text" name="med_freq" class="field-input" placeholder="1× sehari" value="<%= row.freq %>">
                    </div>
                  </div>
                  <div class="mt-3 flex justify-end">
                    <button type="button" class="text-xs font-semibold text-ink-500 hover:text-rose-600" data-clinical-remove>Hapus baris</button>
                  </div>
                </div>
              <% }); %>
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-brand-100 bg-white p-4 sm:p-6">
            <div class="mb-6 flex items-center gap-3">
              <div class="stat-icon" aria-hidden="true">📋</div>
              <div>
                <h2 class="text-xl font-extrabold tracking-tight text-ink-900 sm:text-2xl">Hasil pemeriksaan</h2>
                <p class="text-sm text-ink-500">Untuk tiap jenis: tulis kesimpulan atau unggah PDF hasil.</p>
              </div>
            </div>

            <div class="space-y-6">
              <%- include('../../partials/exam_block', { key: 'ecg', title: 'ECG', hint: 'Elektrokardiogram', exam: examEcg }) %>
              <%- include('../../partials/exam_block', { key: 'echo', title: 'Ekokardiogram', hint: 'Echo jantung', exam: examEcho }) %>
              <%- include('../../partials/exam_block', { key: 'lab', title: 'Laboratorium', hint: 'Hasil lab terkait', exam: examLab }) %>
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-brand-100 bg-white p-4 sm:p-6">
            <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <div class="stat-icon" aria-hidden="true">📅</div>
                <div>
                  <h2 class="text-xl font-extrabold tracking-tight text-ink-900 sm:text-2xl">Janji &amp; kontrol</h2>
                  <p class="text-sm text-ink-500">Jadwal follow-up atau rujukan.</p>
                </div>
              </div>
              <button type="button" class="text-sm font-bold text-brand-800 underline decoration-brand-300 underline-offset-2" data-clinical-add="#appt-rows">
                + Tambah janji
              </button>
            </div>

            <div id="appt-rows" class="space-y-4">
              <% apptRows.forEach(function (a) { %>
                <div class="rounded-2xl border border-slate-100 bg-slate-50/40 p-4" data-clinical-row>
                  <div class="grid gap-4 md:grid-cols-2">
                    <div>
                      <label class="field-label">Tanggal &amp; waktu</label>
                      <input type="datetime-local" name="appt_datetime" class="field-input" value="<%= a.dt %>">
                    </div>
                    <div class="md:col-span-2">
                      <label class="field-label">Catatan</label>
                      <input type="text" name="appt_note" class="field-input" placeholder="Kontrol, prosedur, lokasi…" value="<%= a.note %>">
                    </div>
                  </div>
                  <div class="mt-3 flex justify-end">
                    <button type="button" class="text-xs font-semibold text-ink-500 hover:text-rose-600" data-clinical-remove>Hapus baris</button>
                  </div>
                </div>
              <% }); %>
            </div>
          </section>

          <section class="rounded-[1.75rem] border border-brand-100 bg-white p-4 sm:p-6">
            <div class="mb-6 flex items-center gap-3">
              <div class="stat-icon" aria-hidden="true">📝</div>
              <div>
                <h2 class="text-xl font-extrabold tracking-tight text-ink-900 sm:text-2xl">Catatan klinis</h2>
                <p class="text-sm text-ink-500">Observasi umum, rencana perawatan…</p>
              </div>
            </div>
            <textarea name="clinical_notes" class="field-textarea min-h-[160px]" placeholder="Catatan umum, observasi, rencana perawatan…"><%= notesVal %></textarea>
          </section>

          <% } else { %>

          <section class="rounded-[1.75rem] border border-dashed border-brand-200 bg-white/80 p-6 text-center">
            <p class="text-sm text-ink-600">Jenis form ini memakai kolom standar. Untuk intake kardiologi lengkap, pilih jenis form <strong>Kardiologi</strong> di atas (jika tersedia).</p>
          </section>

          <% } %>

          <div class="sticky bottom-3 z-20 rounded-[1.5rem] border border-white/70 bg-white/95 p-4 shadow-cozy backdrop-blur-sm">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-xs leading-relaxed text-ink-500 sm:text-sm sm:max-w-md">
                Periksa kembali sebelum menyimpan ke rekam medis.
              </p>
              <div class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row sm:justify-end">
                <a href="/admin/patients" class="btn btn-secondary w-full justify-center sm:w-auto">
                  Batal
                </a>
                <button
                  type="submit"
                  class="js-submit-button btn btn-primary w-full px-6 sm:w-auto"
                  data-loading-text="Menyimpan…"
                >
                  Simpan pasien
                </button>
              </div>
            </div>
          </div>
        </form>
        </div>
      </div>

  <%- include('../../partials/admin_shell_close') %>
  <% if (formType === 'cardiology') { %>
  <script src="/js/cardiology-form.js"></script>
  <% } %>
</body>
</html>
